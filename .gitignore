# Obsidian
#  We commit .obsidian/ so the vault config (attachment folder, plugins, Web Clipper
#  template) is reproducible. Per-machine UI ephemera (workspace.json, cache, etc.)
#  is excluded via .obsidian/.gitignore.

# Python (in case future tooling lands)
.venv/
__pycache__/
*.pyc
